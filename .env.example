# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=jarvis-webhook-secret
OWNER_CHAT_ID=your_telegram_chat_id

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase / PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your_fernet_encryption_key

# OpenAI (for Whisper voice transcription)
OPENAI_API_KEY=your_openai_api_key

# App Settings
APP_BASE_URL=https://your-domain.com
DEFAULT_TIMEZONE=Asia/Singapore
BRIEFING_TIME=07:00
LOG_LEVEL=INFO
